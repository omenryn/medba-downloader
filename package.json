{
  "name": "medba-downloader",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node server/scripts/dev.js",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "start": "electron win-desktop-app/main.js",
    "dev:app": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"wait-on tcp:5173 && npm start\"",
    "build:client": "cd client && npm install && npm run build",
    "build:server": "cd server && npm install",
    "build:app": "electron-builder --win -c.extraMetadata.main=win-desktop-app/main.js",
    "build": "npm run build:server && npm run build:client && npm run build:app"
  },
  "build": {
    "appId": "com.medbadownloader.app",
    "productName": "Medba Downloader",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "client/public/assets/favicon.png"
    },
    "extraResources": [
      {
        "from": "win-desktop-app/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "win-desktop-app/main.js",
      "server/**/*",
      "client/dist/**/*",
      "!server/tmp/*",
      "!server/node_modules/**/*"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "is-dev": "^0.2.1",
    "wait-on": "^9.0.4"
  }
}